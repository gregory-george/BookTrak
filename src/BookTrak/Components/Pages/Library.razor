@page "/"
@using BookTrak.Services
@inject ILibraryQueryService LibraryQueryService
@implements IDisposable

<PageTitle>Library — BookTrak</PageTitle>

<div class="page-header">
    <h1>Library</h1>
    <div class="toolbar">
        <input class="search-box"
               type="search"
               placeholder="Search title or author…"
               value="@_searchText"
               @oninput="OnSearchInput" />
        <select class="sort-select" value="@_sort" @onchange="OnSortChanged">
            <option value="@LibrarySortOrder.DateAddedDesc">Recently added</option>
            <option value="@LibrarySortOrder.TitleAsc">Title (A–Z)</option>
            <option value="@LibrarySortOrder.AuthorAsc">Author (A–Z)</option>
            <option value="@LibrarySortOrder.PublishDateDesc">Publish date</option>
        </select>
        <label class="muted">
            <input type="checkbox" checked="@_includeIgnored" @onchange="OnIncludeIgnoredChanged" />
            Show ignored
        </label>
    </div>
</div>

@if (_loading && _rows.Count == 0)
{
    <p class="muted">Loading…</p>
}
else if (_rows.Count == 0)
{
    <div class="empty-state">
        @if (!string.IsNullOrWhiteSpace(_searchText))
        {
            <p>No books match "@_searchText".</p>
        }
        else
        {
            <p>Your library is empty. Add a book to get started.</p>
        }
    </div>
}
else
{
    <p class="muted">@_totalBooks book@(_totalBooks == 1 ? "" : "s")</p>

    <div class="library-scroll">
        <Virtualize @ref="_virtualizeRef" Context="row" ItemsProvider="LoadRowsAsync">
            <div class="book-grid book-row">
                @foreach (var book in row)
                {
                    <BookCard Book="book" />
                }
            </div>
        </Virtualize>
    </div>
}

@code {
    private const int ColumnsPerRow = 5;

    private List<LibraryBookSummary[]> _rows = [];
    private Virtualize<LibraryBookSummary[]>? _virtualizeRef;
    private string? _searchText;
    private LibrarySortOrder _sort = LibrarySortOrder.DateAddedDesc;
    private bool _includeIgnored;
    private bool _loading = true;
    private int _totalBooks;
    private CancellationTokenSource? _debounceCts;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var books = await LibraryQueryService.GetLibraryAsync(new LibraryQuery(_searchText, _sort, _includeIgnored));
        _totalBooks = books.Count;
        _rows = books.Chunk(ColumnsPerRow).ToList();
        _loading = false;

        if (_virtualizeRef is not null)
        {
            await _virtualizeRef.RefreshDataAsync();
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString();

        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        var cts = new CancellationTokenSource();
        _debounceCts = cts;
        _ = DebounceLoadAsync(cts.Token);
    }

    private async Task DebounceLoadAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(300, token);
            if (!token.IsCancellationRequested)
            {
                await LoadAsync();
                StateHasChanged();
            }
        }
        catch (TaskCanceledException)
        {
            // superseded by a newer keystroke
        }
    }

    private async Task OnSortChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<LibrarySortOrder>(e.Value?.ToString(), out var sort))
        {
            _sort = sort;
            await LoadAsync();
        }
    }

    private async Task OnIncludeIgnoredChanged(ChangeEventArgs e)
    {
        _includeIgnored = e.Value is true;
        await LoadAsync();
    }

    public void Dispose() => _debounceCts?.Cancel();

    private ValueTask<ItemsProviderResult<LibraryBookSummary[]>> LoadRowsAsync(ItemsProviderRequest request)
    {
        var page = _rows.Skip(request.StartIndex).Take(request.Count).ToArray();
        return ValueTask.FromResult(new ItemsProviderResult<LibraryBookSummary[]>(page, _rows.Count));
    }
}
