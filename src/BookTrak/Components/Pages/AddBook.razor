@page "/add/book"
@using BookTrak.Audible.Models
@using BookTrak.Services
@inject ILibraryWriteService LibraryWriteService
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Add Book — BookTrak</PageTitle>

<div class="page-header">
    <h1>Add Book</h1>
</div>

<div class="toolbar">
    <input class="search-box"
           type="search"
           placeholder="Search Open Library books…"
           value="@_searchText"
           @oninput="OnSearchInput" />
</div>

@if (_error is not null)
{
    <div class="empty-state"><p>@_error</p></div>
}

@if (_searching)
{
    <p class="muted">Searching…</p>
}
else if (!string.IsNullOrWhiteSpace(_searchText) && _results.Count == 0)
{
    <div class="empty-state"><p>No Open Library books match "@_searchText".</p></div>
}
else if (_results.Count > 0)
{
    <p class="muted">Click a column to sort, Ctrl-click to add a level.</p>
    <table class="editions-table">
        <thead>
            <tr>
                <th class="sortable" @onclick="e => OnHeaderClick(SearchColumn.Title, e)">Title@(SortIndicator(SearchColumn.Title))</th>
                <th class="sortable" @onclick="e => OnHeaderClick(SearchColumn.Author, e)">Author(s)@(SortIndicator(SearchColumn.Author))</th>
                <th class="sortable" @onclick="e => OnHeaderClick(SearchColumn.FirstPublished, e)">First published@(SortIndicator(SearchColumn.FirstPublished))</th>
                <th class="sortable" @onclick="e => OnHeaderClick(SearchColumn.Rating, e)">Rating@(SortIndicator(SearchColumn.Rating))</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var result in _results)
            {
                <tr>
                    <td>@result.Title</td>
                    <td>@(string.IsNullOrEmpty(result.AuthorNames) ? "—" : result.AuthorNames)</td>
                    <td>@(result.FirstPublishYear?.ToString() ?? "—")</td>
                    <td>@(result.RatingsAverage is { } avg ? $"{avg:0.0} ({result.RatingsCount} ratings)" : "—")</td>
                    <td>
                        @if (result.AlreadyInLibrary)
                        {
                            <a href="@($"books/{result.LocalBookId}")">Already in library</a>
                        }
                        else
                        {
                            <button class="btn-primary" disabled="@(_adding == result.OpenLibraryWorkId)" @onclick="() => AddAsync(result)">
                                @(_adding == result.OpenLibraryWorkId ? "Adding…" : "Add")
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<h2 style="margin-top:2rem;">No match on Open Library?</h2>

<p class="muted">Try the audiobook catalog — many titles Open Library doesn't carry are on Audible.</p>
<div class="toolbar">
    <button class="btn-primary" disabled="@(string.IsNullOrWhiteSpace(_searchText) || _searchingAudiobooks)" @onclick="SearchAudiobooksAsync">
        @(_searchingAudiobooks ? "Searching audiobooks…" : "Search audiobooks instead")
    </button>
    @if (string.IsNullOrWhiteSpace(_searchText))
    {
        <span class="muted">Type a title and/or author above first.</span>
    }
</div>

@if (_audiobookError is not null)
{
    <div class="empty-state"><p>@_audiobookError</p></div>
}
else if (_audiobookHits is { Count: 0 })
{
    <div class="empty-state"><p>No audiobooks match "@_searchText" — add the book manually below.</p></div>
}
else if (_audiobookHits is { Count: > 0 })
{
    <p class="muted">Pick the audiobook to add — it becomes a new book with this audiobook as its preferred edition.</p>
    <table class="editions-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author(s)</th>
                <th>Narrator(s)</th>
                <th>Publisher</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var hit in _audiobookHits)
            {
                var c = hit.Candidate;
                <tr>
                    <td>@c.Title@(string.IsNullOrWhiteSpace(c.Subtitle) ? "" : $" — {c.Subtitle}")</td>
                    <td>@(c.Authors.Count > 0 ? string.Join(", ", c.Authors) : "—")</td>
                    <td>@(c.Narrators.Count > 0 ? string.Join(", ", c.Narrators) : "—")</td>
                    <td>@(c.PublisherName ?? "—")</td>
                    <td>
                        @if (hit.AlreadyInLibrary)
                        {
                            <a href="@($"books/{hit.LocalBookId}")">Already in library</a>
                        }
                        else
                        {
                            <button class="btn-primary" disabled="@(_addingAudiobook == c.Asin)" @onclick="() => AddFromAudiobookAsync(c)">
                                @(_addingAudiobook == c.Asin ? "Adding…" : "Add")
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<h3 style="margin-top:2rem;">Still nothing?</h3>
<p class="muted">Add the book manually — enrich it with editions later, or use Add by ISBN.</p>
<div class="toolbar">
    <input class="search-box" type="text" placeholder="Book title" @bind="_manualTitle" @bind:event="oninput" />
    <button class="btn-primary" disabled="@(string.IsNullOrWhiteSpace(_manualTitle) || _addingManual)" @onclick="AddManualAsync">
        @(_addingManual ? "Adding…" : "Add manually")
    </button>
</div>

@code {
    private string? _searchText;
    private string? _manualTitle;
    private List<WorkSearchResult> _results = [];
    private bool _searching;
    private bool _addingManual;
    private string? _adding;
    private string? _error;
    private CancellationTokenSource? _debounceCts;

    private bool _searchingAudiobooks;
    private IReadOnlyList<AudiobookSearchHit>? _audiobookHits;
    private string? _audiobookError;
    private string? _addingAudiobook;

    private enum SearchColumn { Title, Author, FirstPublished, Rating }

    // Active sort levels in priority order; the first is primary, the rest are tie-breakers.
    // Empty by default so results keep Open Library's relevance order until the user sorts.
    private readonly List<(SearchColumn Col, bool Desc)> _sorts = [];

    /// <summary>Plain click sorts by the clicked column alone, toggling asc/desc if it's already
    /// the sole sort. Ctrl-click keeps existing levels and cycles the clicked column through
    /// asc → desc → off, so you can build a multi-column sort.</summary>
    private void OnHeaderClick(SearchColumn col, MouseEventArgs e)
    {
        var idx = _sorts.FindIndex(s => s.Col == col);

        if (e.CtrlKey || e.MetaKey)
        {
            if (idx < 0)
            {
                _sorts.Add((col, false));
            }
            else if (!_sorts[idx].Desc)
            {
                _sorts[idx] = (col, true);
            }
            else
            {
                _sorts.RemoveAt(idx);
            }
        }
        else if (idx >= 0 && _sorts.Count == 1)
        {
            _sorts[0] = (col, !_sorts[0].Desc);
        }
        else
        {
            _sorts.Clear();
            _sorts.Add((col, false));
        }

        ApplySort();
    }

    private void ApplySort()
    {
        if (_sorts.Count == 0)
        {
            return;
        }

        var sorted = _results.ToList();
        sorted.Sort(CompareRows);
        _results = sorted;
    }

    private int CompareRows(WorkSearchResult a, WorkSearchResult b)
    {
        foreach (var (col, desc) in _sorts)
        {
            var c = CompareColumn(a, b, col);
            if (c != 0)
            {
                return desc ? -c : c;
            }
        }

        return 0;
    }

    private static int CompareColumn(WorkSearchResult a, WorkSearchResult b, SearchColumn col) => col switch
    {
        SearchColumn.Title => string.Compare(a.Title, b.Title, StringComparison.OrdinalIgnoreCase),
        SearchColumn.Author => string.Compare(a.AuthorNames, b.AuthorNames, StringComparison.OrdinalIgnoreCase),
        SearchColumn.FirstPublished => Nullable.Compare(a.FirstPublishYear, b.FirstPublishYear),
        SearchColumn.Rating => Nullable.Compare(a.RatingsAverage, b.RatingsAverage),
        _ => 0,
    };

    /// <summary>The arrow (and, when more than one level is active, the priority number) shown
    /// next to a sortable header.</summary>
    private MarkupString SortIndicator(SearchColumn col)
    {
        var idx = _sorts.FindIndex(s => s.Col == col);
        if (idx < 0)
        {
            return (MarkupString)string.Empty;
        }

        var arrow = _sorts[idx].Desc ? "▼" : "▲";
        var rank = _sorts.Count > 1 ? $"<sup>{idx + 1}</sup>" : string.Empty;
        return (MarkupString)$" {arrow}{rank}";
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString();
        _error = null;

        // A new OL query invalidates any audiobook results shown for the previous one.
        _audiobookHits = null;
        _audiobookError = null;

        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        var cts = new CancellationTokenSource();
        _debounceCts = cts;
        _ = DebounceSearchAsync(cts.Token);
    }

    private async Task DebounceSearchAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(300, token);
            if (token.IsCancellationRequested)
            {
                return;
            }

            if (string.IsNullOrWhiteSpace(_searchText))
            {
                _results = [];
                StateHasChanged();
                return;
            }

            _searching = true;
            StateHasChanged();

            try
            {
                _results = (await LibraryWriteService.SearchWorksAsync(_searchText, token)).ToList();
                ApplySort();
            }
            catch (Exception ex) when (ex is not OperationCanceledException)
            {
                _error = "Couldn't reach Open Library — check your connection and try again.";
                _results = [];
            }

            _searching = false;
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            // superseded by a newer keystroke
        }
    }

    private async Task AddAsync(WorkSearchResult result)
    {
        if (result.OpenLibraryWorkId is null)
        {
            return;
        }

        _adding = result.OpenLibraryWorkId;
        StateHasChanged();

        try
        {
            var added = await LibraryWriteService.AddBookFromOpenLibraryAsync(result.OpenLibraryWorkId);
            // Best-effort: attach a matching audiobook if we find a confident one. Never blocks
            // navigation — failures/misses are swallowed inside the service.
            await LibraryWriteService.TryAutoAttachAudiobookAsync(added.BookId);
            Nav.NavigateTo($"books/{added.BookId}");
        }
        catch (Exception)
        {
            _error = "Couldn't add that book — check your connection and try again.";
            _adding = null;
        }
    }

    private async Task SearchAudiobooksAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return;
        }

        _searchingAudiobooks = true;
        _audiobookError = null;
        _audiobookHits = null;
        StateHasChanged();

        var result = await LibraryWriteService.SearchAudiobooksAsync(_searchText.Trim());
        _audiobookHits = result.Hits;
        _audiobookError = result.Error is not null
            ? "Audible search is unavailable right now — add the book manually below."
            : null;

        _searchingAudiobooks = false;
        StateHasChanged();
    }

    private async Task AddFromAudiobookAsync(AudiobookCandidate candidate)
    {
        _addingAudiobook = candidate.Asin;
        _audiobookError = null;
        StateHasChanged();

        try
        {
            var added = await LibraryWriteService.AddBookFromAudiobookAsync(candidate.Asin);
            Nav.NavigateTo($"books/{added.BookId}");
        }
        catch (Exception)
        {
            _audiobookError = "Couldn't add that audiobook — audnexus may be unavailable. Try another match or add the book manually.";
            _addingAudiobook = null;
        }
    }

    private async Task AddManualAsync()
    {
        if (string.IsNullOrWhiteSpace(_manualTitle))
        {
            return;
        }

        _addingManual = true;
        StateHasChanged();

        var added = await LibraryWriteService.AddManualBookAsync(_manualTitle.Trim());
        Nav.NavigateTo($"books/{added.BookId}");
    }

    public void Dispose() => _debounceCts?.Cancel();
}
