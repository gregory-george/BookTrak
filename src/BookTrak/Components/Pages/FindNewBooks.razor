@page "/authors/{AuthorId:int}/find-new"
@using BookTrak.Services
@inject ILibraryWriteService LibraryWriteService
@inject NavigationManager Nav

<PageTitle>Find New Books — BookTrak</PageTitle>

<div class="page-header">
    <h1>Find New Books@(_result is not null ? $" — {_result.AuthorName}" : "")</h1>
    <a href="@($"authors/{AuthorId}")">← Back to author</a>
</div>

@if (_error is not null)
{
    <div class="empty-state"><p>@_error</p></div>
}
else if (_loading)
{
    <p class="muted">Fetching the full work list from Open Library — this can take a moment for prolific authors…</p>
}
else if (_result is { Works.Count: 0 })
{
    <div class="empty-state"><p>No gaps — every Open Library work for @_result.AuthorName is already in your library.</p></div>
}
else if (_result is not null)
{
    <p class="muted">@_result.Works.Count book@(_result.Works.Count == 1 ? "" : "s") not yet in your library · click a column to sort, Ctrl-click to add a level</p>

    <div>
        @if (RemainingCount > 0)
        {
            <button class="btn-primary" disabled="@(_addingAll || _adding is not null)" @onclick="AddAllAsync">
                @(_addingAll ? $"Adding… ({_addedCount}/{_addingAllTotal})" : $"Add All ({RemainingCount})")
            </button>
        }
    </div>

    <table class="editions-table">
        <thead>
            <tr>
                <th></th>
                <th class="sortable" @onclick="e => OnHeaderClick(FindNewColumn.Title, e)">Title@(SortIndicator(FindNewColumn.Title))</th>
                <th class="sortable" @onclick="e => OnHeaderClick(FindNewColumn.FirstPublished, e)">First published@(SortIndicator(FindNewColumn.FirstPublished))</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var work in _works)
            {
                <tr>
                    <td style="width:48px;">
                        @if (work.CoverThumbnailUrl is not null)
                        {
                            <img src="@work.CoverThumbnailUrl" alt="" style="width:36px; height:54px; object-fit:cover; border-radius:3px;" />
                        }
                    </td>
                    <td>@work.Title</td>
                    <td>@(work.FirstPublishDate ?? "—")</td>
                    <td>
                        @if (_addedBookIds.TryGetValue(work.OpenLibraryWorkId, out var bookId))
                        {
                            <a href="@($"books/{bookId}")">Added →</a>
                        }
                        else
                        {
                            <button class="btn-primary" disabled="@(_adding == work.OpenLibraryWorkId || _addingAll)" @onclick="() => AddAsync(work)">
                                @(_adding == work.OpenLibraryWorkId ? "Adding…" : "Add")
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter]
    public int AuthorId { get; set; }

    private enum FindNewColumn { Title, FirstPublished }

    private GapListResult? _result;
    private List<GapListWork> _works = [];

    // Active sort levels in priority order; the first is primary, the rest are tie-breakers.
    // Seeded to match the query's default (title ascending).
    private readonly List<(FindNewColumn Col, bool Desc)> _sorts = [(FindNewColumn.Title, false)];
    private bool _loading = true;
    private string? _error;
    private string? _adding;
    private bool _addingAll;
    private int _addedCount;
    private int _addingAllTotal;
    private readonly Dictionary<string, int> _addedBookIds = [];

    private int RemainingCount => _result?.Works.Count(w => !_addedBookIds.ContainsKey(w.OpenLibraryWorkId)) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _result = await LibraryWriteService.GetGapListAsync(AuthorId);
            _works = _result.Works.ToList();
            ApplySort();
        }
        catch (Exception)
        {
            _error = "Couldn't reach Open Library — check your connection and try again.";
        }

        _loading = false;
    }

    /// <summary>Plain click sorts by the clicked column alone, toggling asc/desc if it's already
    /// the sole sort. Ctrl-click keeps existing levels and cycles the clicked column through
    /// asc → desc → off, so you can build a multi-column sort.</summary>
    private void OnHeaderClick(FindNewColumn col, MouseEventArgs e)
    {
        var idx = _sorts.FindIndex(s => s.Col == col);

        if (e.CtrlKey || e.MetaKey)
        {
            if (idx < 0)
            {
                _sorts.Add((col, false));
            }
            else if (!_sorts[idx].Desc)
            {
                _sorts[idx] = (col, true);
            }
            else
            {
                _sorts.RemoveAt(idx);
            }
        }
        else if (idx >= 0 && _sorts.Count == 1)
        {
            _sorts[0] = (col, !_sorts[0].Desc);
        }
        else
        {
            _sorts.Clear();
            _sorts.Add((col, false));
        }

        ApplySort();
    }

    private void ApplySort()
    {
        if (_sorts.Count == 0)
        {
            return;
        }

        var sorted = _works.ToList();
        sorted.Sort(CompareRows);
        _works = sorted;
    }

    private int CompareRows(GapListWork a, GapListWork b)
    {
        foreach (var (col, desc) in _sorts)
        {
            var c = CompareColumn(a, b, col);
            if (c != 0)
            {
                return desc ? -c : c;
            }
        }

        return 0;
    }

    // FirstPublishDate is free text from Open Library (never parsed as a date), so it sorts as a
    // string — nulls sort last so dated works lead.
    private static int CompareColumn(GapListWork a, GapListWork b, FindNewColumn col) => col switch
    {
        FindNewColumn.Title => string.Compare(a.Title, b.Title, StringComparison.OrdinalIgnoreCase),
        FindNewColumn.FirstPublished => string.Compare(
            a.FirstPublishDate ?? "￿", b.FirstPublishDate ?? "￿", StringComparison.OrdinalIgnoreCase),
        _ => 0,
    };

    /// <summary>The arrow (and, when more than one level is active, the priority number) shown
    /// next to a sortable header.</summary>
    private MarkupString SortIndicator(FindNewColumn col)
    {
        var idx = _sorts.FindIndex(s => s.Col == col);
        if (idx < 0)
        {
            return (MarkupString)string.Empty;
        }

        var arrow = _sorts[idx].Desc ? "▼" : "▲";
        var rank = _sorts.Count > 1 ? $"<sup>{idx + 1}</sup>" : string.Empty;
        return (MarkupString)$" {arrow}{rank}";
    }

    private async Task AddAsync(GapListWork work)
    {
        _adding = work.OpenLibraryWorkId;
        StateHasChanged();

        try
        {
            var added = await LibraryWriteService.AddBookFromOpenLibraryAsync(work.OpenLibraryWorkId);
            // Best-effort audiobook attach for single adds (the bulk "Add All" path skips this
            // to stay fast and polite against the unofficial Audible endpoint).
            await LibraryWriteService.TryAutoAttachAudiobookAsync(added.BookId);
            _addedBookIds[work.OpenLibraryWorkId] = added.BookId;
        }
        catch (Exception)
        {
            _error = "Couldn't add that book — check your connection and try again.";
        }

        _adding = null;
        StateHasChanged();
    }

    private async Task AddAllAsync()
    {
        if (_result is null)
        {
            return;
        }

        var toAdd = _result.Works.Where(w => !_addedBookIds.ContainsKey(w.OpenLibraryWorkId)).ToList();

        _addingAll = true;
        _addedCount = 0;
        _addingAllTotal = toAdd.Count;
        var failures = 0;
        StateHasChanged();

        foreach (var work in toAdd)
        {
            try
            {
                var added = await LibraryWriteService.AddBookFromOpenLibraryAsync(work.OpenLibraryWorkId);
                _addedBookIds[work.OpenLibraryWorkId] = added.BookId;
            }
            catch (Exception)
            {
                failures++;
            }

            _addedCount++;
            StateHasChanged();
        }

        _error = failures > 0 ? $"Added {toAdd.Count - failures} of {toAdd.Count} books — {failures} failed. Check your connection and try again for the rest." : null;
        _addingAll = false;
        StateHasChanged();
    }
}
