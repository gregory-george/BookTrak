@page "/books/{BookId:int}"
@using BookTrak.Audible.Models
@using BookTrak.Data.Entities
@using BookTrak.Services
@inject ILibraryQueryService LibraryQueryService
@inject ILibraryWriteService LibraryWriteService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>@(_result?.Book.Title ?? "Book") — BookTrak</PageTitle>

@if (_notFound)
{
    <div class="empty-state">
        <p>Book not found.</p>
        <a href="/">← Back to library</a>
    </div>
}
else if (_result is null)
{
    <p class="muted">Loading…</p>
}
else
{
    var book = _result.Book;

    <div class="book-detail">
        <div class="book-detail-cover">
            @if (CoverWebPath is not null)
            {
                <img src="@CoverWebPath" alt="@book.Title cover" />
            }
            else
            {
                <div class="cover-placeholder" style="width:100%; aspect-ratio:2/3; display:flex; align-items:center; justify-content:center; background: var(--color-border); border-radius: var(--radius); font-size:3rem;">📕</div>
            }
        </div>
        <div class="book-detail-info">
            <h1>@book.Title</h1>
            @if (!string.IsNullOrWhiteSpace(book.Subtitle))
            {
                <p class="book-detail-subtitle">@book.Subtitle</p>
            }

            @if (_result.Authors.Count > 0)
            {
                <p>
                    by
                    @for (var i = 0; i < _result.Authors.Count; i++)
                    {
                        var author = _result.Authors[i];
                        <a href="@($"authors/{author.Id}")">@author.Name</a>
                        @if (i < _result.Authors.Count - 1)
                        {
                            @:,
                        }
                    }
                </p>
            }

            <div class="book-detail-meta">
                <StatusBadge Status="book.Status" />
                @if (book.IsIgnored)
                {
                    <span class="status-badge status-badge-wanttoread">ignored</span>
                }
                @if (book.MyRating is not null)
                {
                    <span>My rating: <StarRating Value="book.MyRating" ShowNumber="true" /></span>
                }
                @if (book.AverageRating is not null)
                {
                    <span>Average: <StarRating Value="book.AverageRating" ShowNumber="true" /> (@book.RatingsCount ratings)</span>
                }
                @if (book.Series is not null)
                {
                    <span><a href="@($"series/{book.Series.Id}")">@book.Series.Name</a> @(book.SeriesPosition is not null ? $"#{book.SeriesPosition}" : "")</span>
                }
                @if (!string.IsNullOrWhiteSpace(book.FirstPublishDate))
                {
                    <span>First published @book.FirstPublishDate</span>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(book.Description))
            {
                <p>@book.Description</p>
            }

            <div class="status-editor">
                <div class="toolbar">
                    <label>
                        Status
                        <select class="sort-select" value="@_status" @onchange="OnStatusChanged">
                            <option value="@BookStatus.None">None</option>
                            <option value="@BookStatus.WantToRead">Want to read</option>
                            <option value="@BookStatus.Reading">Reading</option>
                            <option value="@BookStatus.Read">Read</option>
                        </select>
                    </label>

                    @if (_status is BookStatus.Reading or BookStatus.Read)
                    {
                        <label>
                            Started
                            <input class="search-box" type="date" value="@_dateStarted?.ToString("yyyy-MM-dd")" @onchange="OnDateStartedChanged" />
                        </label>
                    }

                    @if (_status == BookStatus.Read)
                    {
                        <label>
                            Finished
                            <input class="search-box" type="date" value="@_dateRead?.ToString("yyyy-MM-dd")" @onchange="OnDateReadChanged" />
                        </label>

                        <label>
                            My rating
                            <RatingPicker Value="_myRating" ValueChanged="OnRatingChanged" />
                        </label>

                        @if (_result.Editions.Count > 0)
                        {
                            <label>
                                Read edition
                                <select class="sort-select" value="@_readEditionId" @onchange="OnReadEditionChanged">
                                    <option value="">(unspecified)</option>
                                    @foreach (var edition in _result.Editions)
                                    {
                                        <option value="@edition.Id">@edition.Format@(edition.Publisher is not null ? $" — {edition.Publisher}" : "")</option>
                                    }
                                </select>
                            </label>
                        }
                    }

                    <button class="btn-primary" disabled="@_savingStatus" @onclick="SaveStatusAsync">
                        @(_savingStatus ? "Saving…" : "Save")
                    </button>

                    <button class="btn-primary" @onclick="ToggleBookIgnoredAsync">
                        @(book.IsIgnored ? "Un-ignore" : "Ignore")
                    </button>

                    <button class="btn-danger" disabled="@_deleting" @onclick="DeleteBookAsync">
                        @(_deleting ? "Deleting…" : "Delete")
                    </button>
                </div>
                @if (_statusMessage is not null)
                {
                    <p class="muted">@_statusMessage</p>
                }
            </div>

            <div class="status-editor">
                <div class="toolbar">
                    <label>
                        Series
                        <input class="search-box" placeholder="e.g. The Stormlight Archive" value="@_seriesName" @oninput="@(e => _seriesName = e.Value?.ToString())" />
                    </label>
                    <label>
                        Position
                        <input class="search-box" style="width:6rem;" placeholder="e.g. 3.5" value="@_seriesPosition" @oninput="@(e => _seriesPosition = e.Value?.ToString())" />
                    </label>
                    <button class="btn-primary" disabled="@_savingSeries" @onclick="SaveSeriesAsync">
                        @(_savingSeries ? "Saving…" : "Save series")
                    </button>
                </div>
                @if (_seriesMessage is not null)
                {
                    <p class="muted">@_seriesMessage</p>
                }
            </div>

            @if (book.OpenLibraryWorkId is not null)
            {
                <p class="muted" style="margin-top:1rem;">
                    @if (SyncStatus.IsStale(book.LastSyncedUtc))
                    {
                        <span class="status-badge status-badge-wanttoread">stale</span>
                    }
                    @(book.LastSyncedUtc is { } synced ? $" Last synced {synced:yyyy-MM-dd HH:mm} UTC" : " Never synced")
                    <button class="btn-primary" style="margin-left:0.75rem;" disabled="@_refreshing" @onclick="RefreshAsync">
                        @(_refreshing ? "Refreshing…" : "Refresh")
                    </button>
                </p>
                @if (_refreshMessage is not null)
                {
                    <p class="muted">@_refreshMessage</p>
                }
            }
        </div>
    </div>

    <div class="page-header" style="margin-top:2rem;">
        <h2 style="margin:0;">Editions (@_result.Editions.Count)</h2>
        <div class="toolbar">
            <div class="add-edition-menu">
                <button class="btn-primary" @onclick="ToggleAddMenu">
                    @(_addMenuOpen ? "Add edition ▴" : "+ Add edition ▾")
                </button>
                @if (_addMenuOpen)
                {
                    <div class="add-edition-dropdown">
                        <button @onclick="@(() => OpenAddPanel(AddPanel.Manual))">✏️ Manually add information</button>
                        <button @onclick="@(() => OpenAddPanel(AddPanel.Physical))">📖 Search for a physical book</button>
                        <button @onclick="@(() => OpenAddPanel(AddPanel.Audiobook))">🎧 Search for an audiobook</button>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (_addPanel == AddPanel.Physical)
    {
        <div class="status-editor">
            <div class="toolbar">
                <input class="search-box" type="search" placeholder="Search Open Library books…"
                       value="@_physicalSearchText" @oninput="OnPhysicalSearchInput" />
                <button class="btn-primary" @onclick="CloseAddPanel">Cancel</button>
            </div>

            @if (_physicalError is not null)
            {
                <p class="muted">@_physicalError</p>
            }
            else if (_physicalSearching)
            {
                <p class="muted">Searching…</p>
            }
            else if (!string.IsNullOrWhiteSpace(_physicalSearchText) && _physicalResults.Count == 0)
            {
                <p class="muted">No Open Library books match "@_physicalSearchText".</p>
            }
            else if (_physicalResults.Count > 0)
            {
                <p class="muted">Pick the printing to attach to this book as a physical edition.</p>
                <table class="editions-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Author(s)</th>
                            <th>First published</th>
                            <th>Rating</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var result in _physicalResults)
                        {
                            <tr>
                                <td>@result.Title</td>
                                <td>@(string.IsNullOrEmpty(result.AuthorNames) ? "—" : result.AuthorNames)</td>
                                <td>@(result.FirstPublishYear?.ToString() ?? "—")</td>
                                <td>@(result.RatingsAverage is { } avg ? $"{avg:0.0} ({result.RatingsCount} ratings)" : "—")</td>
                                <td>
                                    <button class="btn-primary"
                                            disabled="@(result.OpenLibraryWorkId is null || _addingPhysical == result.OpenLibraryWorkId)"
                                            @onclick="() => AddPhysicalEditionAsync(result)">
                                        @(_addingPhysical == result.OpenLibraryWorkId ? "Adding…" : "Add edition")
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            @if (_addEditionMessage is not null)
            {
                <p class="muted">@_addEditionMessage</p>
            }
        </div>
    }

    @if (_addPanel == AddPanel.Audiobook)
    {
        <div class="status-editor">
            <div class="toolbar">
                <button class="btn-primary" disabled="@_searchingAudiobooks" @onclick="FindMatchingAudiobookAsync">
                    @(_searchingAudiobooks ? "Searching…" : "Search Audible again")
                </button>
                <button class="btn-primary" @onclick="CloseAddPanel">Cancel</button>
            </div>

            @if (_searchingAudiobooks)
            {
                <p class="muted">Searching Audible…</p>
            }
            else if (_audiobookCandidates is { Count: 0 })
            {
                <p class="muted">@(_audiobookMessage ?? "No audiobook matches found on Audible. Add one manually with its ASIN via “Manually add information”.")</p>
            }
            else if (_audiobookCandidates is { Count: > 0 })
            {
                <p class="muted">Audible matches — pick the one to add as an audiobook edition:</p>
                <table class="editions-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Author(s)</th>
                            <th>Narrator(s)</th>
                            <th>Publisher</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var candidate in _audiobookCandidates)
                        {
                            <tr>
                                <td>@candidate.Title@(string.IsNullOrWhiteSpace(candidate.Subtitle) ? "" : $" — {candidate.Subtitle}")</td>
                                <td>@(candidate.Authors.Count > 0 ? string.Join(", ", candidate.Authors) : "—")</td>
                                <td>@(candidate.Narrators.Count > 0 ? string.Join(", ", candidate.Narrators) : "—")</td>
                                <td>@(candidate.PublisherName ?? "—")</td>
                                <td>
                                    <button class="btn-primary" disabled="@(_addingEdition || _addedCandidateAsins.Contains(candidate.Asin))" @onclick="() => AddAudiobookCandidateAsync(candidate)">
                                        @(_addedCandidateAsins.Contains(candidate.Asin) ? "Added" : "Add this audiobook")
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (_audiobookMessage is not null)
                {
                    <p class="muted">@_audiobookMessage</p>
                }
            }
        </div>
    }

    @if (_addPanel == AddPanel.Manual)
    {
        <div class="status-editor">
            <div class="toolbar">
                <label>
                    Format
                    <select class="sort-select" value="@_newEditionFormat" @onchange="OnNewEditionFormatChanged">
                        <option value="@EditionFormat.Physical">Physical</option>
                        <option value="@EditionFormat.Ebook">Ebook</option>
                        <option value="@EditionFormat.Audiobook">Audiobook</option>
                    </select>
                </label>
                <button class="btn-primary" @onclick="CloseAddPanel" style="align-self:end;">Cancel</button>
            </div>

            @if (_newEditionFormat == EditionFormat.Audiobook)
            {
                <div class="toolbar" style="margin-top:0.75rem;">
                    <label>
                        Audible ASIN
                        <input class="search-box" placeholder="e.g. B002V1OF1S" value="@_newEditionAsin" @oninput="@(e => _newEditionAsin = e.Value?.ToString())" />
                    </label>
                    <button class="btn-primary" disabled="@(_addingEdition || string.IsNullOrWhiteSpace(_newEditionAsin))" @onclick="AddFromAsinAsync" style="align-self:end;">
                        @(_addingEdition ? "Fetching…" : "Fetch from audnexus")
                    </button>
                </div>
                <p class="muted" style="margin-top:0.5rem;">Or enter the audiobook details manually below.</p>
            }

            <div class="toolbar" style="margin-top:0.75rem;">
                @if (_newEditionFormat != EditionFormat.Audiobook)
                {
                    <label>
                        ISBN
                        <input class="search-box" value="@_newEditionIsbn" @oninput="@(e => _newEditionIsbn = e.Value?.ToString())" />
                    </label>
                    <label>
                        Pages
                        <input class="search-box" type="number" value="@_newEditionPages" @oninput="@(e => _newEditionPages = int.TryParse(e.Value?.ToString(), out var p) ? p : null)" />
                    </label>
                }
                <label>
                    Language
                    <input class="search-box" value="@_newEditionLanguage" @oninput="@(e => _newEditionLanguage = e.Value?.ToString())" />
                </label>
                <label>
                    Publisher
                    <input class="search-box" value="@_newEditionPublisher" @oninput="@(e => _newEditionPublisher = e.Value?.ToString())" />
                </label>
                <label>
                    Published
                    <input class="search-box" placeholder="e.g. 2021" value="@_newEditionPublishDate" @oninput="@(e => _newEditionPublishDate = e.Value?.ToString())" />
                </label>

                @if (_newEditionFormat == EditionFormat.Audiobook)
                {
                    <label>
                        Narrator
                        <input class="search-box" value="@_newEditionNarrator" @oninput="@(e => _newEditionNarrator = e.Value?.ToString())" />
                    </label>
                    <label>
                        Duration (minutes)
                        <input class="search-box" type="number" value="@_newEditionDurationMinutes" @oninput="@(e => _newEditionDurationMinutes = int.TryParse(e.Value?.ToString(), out var d) ? d : null)" />
                    </label>
                }

                <button class="btn-primary" disabled="@_addingEdition" @onclick="AddManualEditionAsync" style="align-self:end;">
                    @(_addingEdition ? "Adding…" : "Add edition manually")
                </button>
            </div>

            @if (_addEditionMessage is not null)
            {
                <p class="muted">@_addEditionMessage</p>
            }
        </div>
    }

    @if (_result.Editions.Count == 0)
    {
        <div class="empty-state"><p>No editions recorded yet.</p></div>
    }
    else
    {
        <table class="editions-table">
            <thead>
                <tr>
                    <th>Cover</th>
                    <th>Format</th>
                    <th>ISBN</th>
                    <th>ASIN</th>
                    <th>Pages</th>
                    <th>Language</th>
                    <th>Publisher</th>
                    <th>Published</th>
                    <th>Narrator</th>
                    <th>Duration</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var edition in _result.Editions)
                {
                    <tr>
                        <td>
                            @{
                                var editionCover = CoverPaths.ToWebPath(edition.CoverPath);
                            }
                            @if (editionCover is not null)
                            {
                                <img class="edition-cover-thumb" src="@editionCover" alt="@(edition.Format) cover" />
                            }
                            else
                            {
                                <div class="edition-cover-thumb edition-cover-thumb-placeholder">@(edition.Format == EditionFormat.Audiobook ? "🎧" : "📕")</div>
                            }
                        </td>
                        <td>
                            @edition.Format
                            @if (book.PreferredEditionId == edition.Id)
                            {
                                <span class="muted"> (preferred)</span>
                            }
                            @if (edition.IsIgnored)
                            {
                                <span class="muted"> (ignored)</span>
                            }
                        </td>
                        <td>@(edition.Isbn13 ?? edition.Isbn10 ?? "—")</td>
                        <td>@(edition.Asin ?? "—")</td>
                        <td>@(edition.NumberOfPages?.ToString() ?? "—")</td>
                        <td>@(edition.Language ?? "—")</td>
                        <td>@(edition.Publisher ?? "—")</td>
                        <td>@(edition.PublishDate ?? "—")</td>
                        <td>@(edition.Narrator ?? "—")</td>
                        <td>@FormatDuration(edition.DurationSeconds)</td>
                        <td>
                            <button class="btn-danger" disabled="@(_deletingEditionId == edition.Id)" @onclick="() => DeleteEditionAsync(edition.Id)">
                                @(_deletingEditionId == edition.Id ? "Deleting…" : "Delete")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter]
    public int BookId { get; set; }

    private BookDetailResult? _result;
    private bool _notFound;
    private bool _refreshing;
    private string? _refreshMessage;

    private BookStatus _status;
    private DateTime? _dateStarted;
    private DateTime? _dateRead;
    private double? _myRating;
    private int? _readEditionId;
    private bool _savingStatus;
    private string? _statusMessage;

    private string? _seriesName;
    private string? _seriesPosition;
    private bool _savingSeries;
    private string? _seriesMessage;

    private bool _addMenuOpen;
    private enum AddPanel { None, Manual, Physical, Audiobook }
    private AddPanel _addPanel = AddPanel.None;

    private string? _physicalSearchText;
    private List<WorkSearchResult> _physicalResults = [];
    private bool _physicalSearching;
    private string? _physicalError;
    private string? _addingPhysical;
    private CancellationTokenSource? _physicalDebounceCts;

    private EditionFormat _newEditionFormat;
    private string? _newEditionAsin;
    private string? _newEditionIsbn;
    private int? _newEditionPages;
    private string? _newEditionLanguage;
    private string? _newEditionPublisher;
    private string? _newEditionPublishDate;
    private string? _newEditionNarrator;
    private int? _newEditionDurationMinutes;
    private bool _addingEdition;
    private string? _addEditionMessage;

    private bool _searchingAudiobooks;
    private IReadOnlyList<AudiobookCandidate>? _audiobookCandidates;
    private string? _audiobookMessage;
    private readonly HashSet<string> _addedCandidateAsins = [];

    private string? CoverWebPath => CoverPaths.ToWebPath(_result?.Book.PreferredEdition?.CoverPath);

    protected override async Task OnParametersSetAsync()
    {
        _result = null;
        _notFound = false;
        _refreshMessage = null;
        _statusMessage = null;
        _audiobookCandidates = null;
        _audiobookMessage = null;
        _addedCandidateAsins.Clear();
        _addMenuOpen = false;
        _addPanel = AddPanel.None;
        _addEditionMessage = null;
        _physicalSearchText = null;
        _physicalResults = [];
        _physicalError = null;
        _addingPhysical = null;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var result = await LibraryQueryService.GetBookDetailAsync(BookId, includeIgnoredEditions: true);
        if (result is null)
        {
            _notFound = true;
            return;
        }

        _result = result;
        _status = result.Book.Status;
        _dateStarted = result.Book.DateStarted;
        _dateRead = result.Book.DateRead;
        _myRating = result.Book.MyRating;
        _readEditionId = result.Book.ReadEditionId;
        _seriesName = result.Book.Series?.Name;
        _seriesPosition = result.Book.SeriesPosition;
    }

    private void OnStatusChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<BookStatus>(e.Value?.ToString(), out var status))
        {
            _status = status;
            if (status == BookStatus.Reading && _dateStarted is null)
            {
                _dateStarted = DateTime.Today;
            }
            else if (status == BookStatus.Read && _dateRead is null)
            {
                _dateRead = DateTime.Today;
            }
        }
    }

    private void OnDateStartedChanged(ChangeEventArgs e)
        => _dateStarted = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : null;

    private void OnDateReadChanged(ChangeEventArgs e)
        => _dateRead = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : null;

    private void OnRatingChanged(double? value) => _myRating = value;

    private void OnReadEditionChanged(ChangeEventArgs e)
        => _readEditionId = int.TryParse(e.Value?.ToString(), out var id) ? id : null;

    private async Task SaveStatusAsync()
    {
        _savingStatus = true;
        _statusMessage = null;
        StateHasChanged();

        await LibraryWriteService.UpdateStatusAsync(
            BookId,
            _status,
            _status is BookStatus.Reading or BookStatus.Read ? _dateStarted : null,
            _status == BookStatus.Read ? _dateRead : null,
            _status == BookStatus.Read ? _myRating : null,
            _status == BookStatus.Read ? _readEditionId : null);

        await LoadAsync();
        _statusMessage = "Saved.";
        _savingStatus = false;
        StateHasChanged();
    }

    private async Task SaveSeriesAsync()
    {
        _savingSeries = true;
        _seriesMessage = null;
        StateHasChanged();

        await LibraryWriteService.SetBookSeriesAsync(BookId, _seriesName, _seriesPosition);
        await LoadAsync();
        _seriesMessage = "Saved.";
        _savingSeries = false;
        StateHasChanged();
    }

    private async Task ToggleBookIgnoredAsync()
    {
        if (_result is null)
        {
            return;
        }

        await LibraryWriteService.SetBookIgnoredAsync(BookId, !_result.Book.IsIgnored);
        await LoadAsync();
    }

    private bool _deleting;

    private async Task DeleteBookAsync()
    {
        if (_deleting || _result is null)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Delete “{_result.Book.Title}” and all of its editions? This can't be undone.");
        if (!confirmed)
        {
            return;
        }

        _deleting = true;
        StateHasChanged();

        await LibraryWriteService.DeleteBookAsync(BookId);
        Navigation.NavigateTo("/");
    }

    private int? _deletingEditionId;

    private async Task DeleteEditionAsync(int editionId)
    {
        if (_deletingEditionId is not null)
        {
            return;
        }

        var edition = _result?.Editions.FirstOrDefault(e => e.Id == editionId);
        if (edition is null)
        {
            return;
        }

        var label = edition.Format + (edition.Publisher is not null ? $" — {edition.Publisher}" : "");
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Delete the {label} edition? This can't be undone.");
        if (!confirmed)
        {
            return;
        }

        _deletingEditionId = editionId;
        StateHasChanged();

        await LibraryWriteService.DeleteEditionAsync(editionId);
        await LoadAsync();

        _deletingEditionId = null;
        StateHasChanged();
    }

    private void ToggleAddMenu() => _addMenuOpen = !_addMenuOpen;

    private void OpenAddPanel(AddPanel panel)
    {
        _addMenuOpen = false;
        _addPanel = panel;
        _addEditionMessage = null;

        switch (panel)
        {
            case AddPanel.Manual:
                ResetNewEditionForm();
                break;
            case AddPanel.Physical:
                _physicalError = null;
                _physicalResults = [];
                _physicalSearchText = _result?.Book.Title;
                TriggerPhysicalSearch();
                break;
            case AddPanel.Audiobook:
                _ = FindMatchingAudiobookAsync();
                break;
        }
    }

    private void CloseAddPanel()
    {
        _addPanel = AddPanel.None;
        _addEditionMessage = null;
    }

    private void OnPhysicalSearchInput(ChangeEventArgs e)
    {
        _physicalSearchText = e.Value?.ToString();
        _physicalError = null;
        TriggerPhysicalSearch();
    }

    private void TriggerPhysicalSearch()
    {
        _physicalDebounceCts?.Cancel();
        _physicalDebounceCts?.Dispose();
        var cts = new CancellationTokenSource();
        _physicalDebounceCts = cts;
        _ = DebouncePhysicalSearchAsync(cts.Token);
    }

    private async Task DebouncePhysicalSearchAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(300, token);
            if (token.IsCancellationRequested)
            {
                return;
            }

            if (string.IsNullOrWhiteSpace(_physicalSearchText))
            {
                _physicalResults = [];
                StateHasChanged();
                return;
            }

            _physicalSearching = true;
            StateHasChanged();

            try
            {
                _physicalResults = (await LibraryWriteService.SearchWorksAsync(_physicalSearchText, token)).ToList();
            }
            catch (Exception ex) when (ex is not OperationCanceledException)
            {
                _physicalError = "Couldn't reach Open Library — check your connection and try again.";
                _physicalResults = [];
            }

            _physicalSearching = false;
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            // superseded by a newer keystroke
        }
    }

    private async Task AddPhysicalEditionAsync(WorkSearchResult result)
    {
        if (result.OpenLibraryWorkId is null)
        {
            return;
        }

        _addingPhysical = result.OpenLibraryWorkId;
        _addEditionMessage = null;
        StateHasChanged();

        var addResult = await LibraryWriteService.AddEditionFromOpenLibraryWorkAsync(BookId, result.OpenLibraryWorkId);
        if (addResult.Success)
        {
            _addPanel = AddPanel.None;
            await LoadAsync();
        }
        else
        {
            _addEditionMessage = addResult.Error;
        }

        _addingPhysical = null;
        StateHasChanged();
    }

    private void OnNewEditionFormatChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<EditionFormat>(e.Value?.ToString(), out var format))
        {
            _newEditionFormat = format;
        }
    }

    private void ResetNewEditionForm()
    {
        _newEditionFormat = EditionFormat.Physical;
        _newEditionAsin = null;
        _newEditionIsbn = null;
        _newEditionPages = null;
        _newEditionLanguage = null;
        _newEditionPublisher = null;
        _newEditionPublishDate = null;
        _newEditionNarrator = null;
        _newEditionDurationMinutes = null;
    }

    private async Task AddFromAsinAsync()
    {
        if (string.IsNullOrWhiteSpace(_newEditionAsin))
        {
            return;
        }

        _addingEdition = true;
        _addEditionMessage = null;
        StateHasChanged();

        var result = await LibraryWriteService.AddAudiobookEditionByAsinAsync(BookId, _newEditionAsin.Trim());
        if (result.Success)
        {
            _addPanel = AddPanel.None;
            await LoadAsync();
        }
        else
        {
            _addEditionMessage = result.Error;
        }

        _addingEdition = false;
        StateHasChanged();
    }

    private async Task AddManualEditionAsync()
    {
        _addingEdition = true;
        _addEditionMessage = null;
        StateHasChanged();

        var result = await LibraryWriteService.AddManualEditionAsync(
            BookId,
            _newEditionFormat,
            _newEditionIsbn,
            _newEditionPages,
            _newEditionLanguage,
            _newEditionPublisher,
            _newEditionPublishDate,
            _newEditionNarrator,
            _newEditionDurationMinutes,
            _newEditionPublisher,
            _newEditionAsin);

        if (result.Success)
        {
            _addPanel = AddPanel.None;
            await LoadAsync();
        }
        else
        {
            _addEditionMessage = result.Error;
        }

        _addingEdition = false;
        StateHasChanged();
    }

    private async Task FindMatchingAudiobookAsync()
    {
        _searchingAudiobooks = true;
        _audiobookMessage = null;
        _audiobookCandidates = null;
        StateHasChanged();

        var result = await LibraryWriteService.SearchAudiobookCandidatesAsync(BookId);
        _audiobookCandidates = result.Candidates;
        _audiobookMessage = result.Error is not null
            ? "Audible search is unavailable right now — add an audiobook manually with its ASIN below."
            : null;

        _searchingAudiobooks = false;
        StateHasChanged();
    }

    private async Task AddAudiobookCandidateAsync(AudiobookCandidate candidate)
    {
        _addingEdition = true;
        _audiobookMessage = null;
        StateHasChanged();

        var result = await LibraryWriteService.AddAudiobookEditionByAsinAsync(BookId, candidate.Asin);
        if (result.Success)
        {
            _addedCandidateAsins.Add(candidate.Asin);
            await LoadAsync();
        }
        else
        {
            _audiobookMessage = result.Error;
        }

        _addingEdition = false;
        StateHasChanged();
    }

    private async Task RefreshAsync()
    {
        _refreshing = true;
        _refreshMessage = null;
        StateHasChanged();

        var result = await LibraryWriteService.RefreshBookAsync(BookId);
        _refreshMessage = result.Success
            ? $"Updated{(result.NewEditionsAdded > 0 ? $" — {result.NewEditionsAdded} new edition{(result.NewEditionsAdded == 1 ? "" : "s")} added" : "")}."
            : result.Error;

        if (result.Success)
        {
            await LoadAsync();
        }

        _refreshing = false;
        StateHasChanged();
    }

    private static string FormatDuration(int? seconds)
    {
        if (seconds is null)
        {
            return "—";
        }

        var span = TimeSpan.FromSeconds(seconds.Value);
        return span.Hours > 0
            ? $"{span.Hours}h {span.Minutes}m"
            : $"{span.Minutes}m {span.Seconds}s";
    }

    public void Dispose() => _physicalDebounceCts?.Cancel();
}
