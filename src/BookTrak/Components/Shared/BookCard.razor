@using BookTrak.Services

<a class="book-card" href="@($"books/{Book.Id}")">
    <div class="book-card-cover">
        @if (Book.CoverWebPath is not null)
        {
            <img src="@Book.CoverWebPath" alt="@Book.Title cover" loading="lazy" />
        }
        else
        {
            <span class="cover-placeholder">📕</span>
        }
    </div>
    <div class="book-card-body">
        <div class="book-card-title">@Book.Title</div>
        @if (!string.IsNullOrWhiteSpace(Book.AuthorNames))
        {
            <div class="book-card-author">@Book.AuthorNames</div>
        }
        @if (Book.EarliestPublishYear is not null || Book.EditionCount > 0)
        {
            <div class="book-card-meta">
                @if (Book.EarliestPublishYear is not null)
                {
                    <span>@Book.EarliestPublishYear</span>
                }
                @if (Book.EditionCount > 0)
                {
                    <span>@Book.EditionCount edition@(Book.EditionCount == 1 ? "" : "s")</span>
                }
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Book.Description))
        {
            <div class="book-card-description">@Book.Description</div>
        }
        <div class="book-card-footer">
            <StarRating Value="@(Book.MyRating ?? Book.AverageRating)" />
            <StatusBadge Status="Book.Status" />
        </div>
    </div>
</a>

@code {
    [Parameter, EditorRequired]
    public LibraryBookSummary Book { get; set; } = null!;
}
